#################################################
# ThePhoenixEngine
# Environment Configuration
# DO NOT COMMIT THIS FILE TO GITHUB
#################################################

# Server
PORT=3000
NODE_ENV=development
API_VERSION=v1

# =================================================
# GROQ API
# =================================================
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =================================================
# SECURITY
# =================================================
JWT_SECRET=replace_with_a_long_random_secret_key
LICENSE_SECRET=replace_with_another_random_secret

# =================================================
# DATABASE (Future)
# =================================================
DATABASE_URL=

# =================================================
# BILLING (Future)
# =================================================
STRIPE_SECRET_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# =================================================
# EMAIL (Future)
# =================================================
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# =================================================
# STORAGE (Future)
# =================================================
STORAGE_PROVIDER=local

# =================================================
# LOGGING
# =================================================
ENABLE_LOGS=true
LOG_LEVEL=info
